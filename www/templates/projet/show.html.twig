{% extends 'base.html.twig' %}

{% block title %}Détails du Projet{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1 class="mb-4">Détails du Projet : <span class="text-primary">{{ projet.nom }}</span></h1>

        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Informations sur le projet</h5>
            </div>
            <div class="card-body">
                <table class="table table-bordered">
                    <tbody>
                        <tr>
                            <th scope="row" class="bg-light">Projet ID</th>
                            <td>{{ projet.projetid }}</td>
                        </tr>
                        <tr>
                            <th scope="row" class="bg-light">Nom</th>
                            <td>{{ projet.nom }}</td>
                        </tr>
                        <tr>
                            <th scope="row" class="bg-light">Budget Initial</th>
                            <td>{{ projet.budgetinitial }}</td>
                        </tr>
                        <tr>
                            <th scope="row" class="bg-light">Seuil d'Alerte</th>
                            <td>{{ projet.seuilalerte }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

                <div class="mt-4">
                        <a href="{{ path('app_projet_index') }}" class="btn btn-secondary btn-sm">Retour à la liste</a>
                        <a href="{{ path('app_projet_edit', {'projetid': projet.projetid}) }}" class="btn btn-warning btn-sm">Modifier</a>

                        <form id="send-recap-form" method="post" action="{{ path('app_project_send_recap', {'projetid': projet.projetid}) }}" style="display:inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('send_recap' ~ projet.projetid) }}">
                                <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#confirmSendRecap">Envoyer rapport</button>

                        <div class="modal fade" id="confirmSendRecap" tabindex="-1" aria-labelledby="confirmSendRecapLabel" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="confirmSendRecapLabel">Confirmer l'envoi</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        Voulez-vous envoyer le récapitulatif PDF au contact facturation du client ?
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                                        <button type="button" id="confirmSendRecapBtn" class="btn btn-primary">Confirmer et envoyer</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <script>
                            (function(){
                                const btn = document.getElementById('confirmSendRecapBtn');
                                if(btn){
                                    btn.addEventListener('click', function(){
                                        // submit the form
                                        document.getElementById('send-recap-form').submit();
                                    });
                                }
                            })();
                        </script>
                        </form>
                </div>

        <div class="mt-4">
            {{ include('projet/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
